      "parameters": {
        "jsCode": "// 1. Get the raw text from the input\nconst rawText = $input.item.json.output; \n\n// 2. Extract the Subject line using Regex\nconst subjectMatch = rawText.match(/Subject:\\s*(.*)/i);\nconst emailSubject = subjectMatch ? subjectMatch[1].trim() : \"Заявка за връщане на продукт\";\n\n// 3. Extract the Body (everything after the first two newlines)\n// This removes the \"Subject: ...\" part from the final message\nconst emailBody = rawText.replace(/Subject:.*\\n*/i, \"\").trim();\n\n// 4. Return as a clean JSON object for the next node\nreturn {\n  subject: emailSubject,\n  body: emailBody\n};"
